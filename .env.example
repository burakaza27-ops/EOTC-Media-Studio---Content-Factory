# ═══════════════════════════════════════════════════════════════
# EOTC MEDIA STUDIO - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# AI Configuration (REQUIRED)
# ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model selection (default: Gemini 2.0 Flash)
# Options: google/gemini-2.0-flash-001, anthropic/claude-4-sonnet
AI_MODEL=google/gemini-2.0-flash-001

# ─────────────────────────────────────────────────────────────
# Supabase Configuration (OPTIONAL - for duplicate prevention)
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ...
# Table name for quotes storage (default: quotes)
SUPABASE_TABLE=quotes

# ─────────────────────────────────────────────────────────────
# Telegram Configuration (OPTIONAL - for notifications)
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# ─────────────────────────────────────────────────────────────
# Puppeteer Configuration (auto-detected)
# ─────────────────────────────────────────────────────────────
# For GitHub Actions: PUPPETEER_EXEC_PATH=/usr/bin/google-chrome
# For local: leave empty (auto-detect)
PUPPETEER_EXEC_PATH=

# ─────────────────────────────────────────────────────────────
# Logging Configuration
# ─────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# Pipeline Configuration
# ─────────────────────────────────────────────────────────────
# Enable verbose error reporting
VERBOSE_ERRORS=true